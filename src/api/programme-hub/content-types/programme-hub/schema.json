{
  "kind": "collectionType",
  "collectionName": "programme_hubs",
  "info": {
    "singularName": "programme-hub",
    "pluralName": "programme-hubs",
    "displayName": "Programme Hub"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "programme_type": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "enum": [
        "master",
        "lateral",
        "manual-therapy",
        "omt-egypt"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "subtitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "intro": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "campus_cards": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "programme.campus-card",
      "repeatable": true
    },
    "breadcrumb_label": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "campuses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::programme-campus.programme-campus",
      "mappedBy": "programme"
    }
  }
}
