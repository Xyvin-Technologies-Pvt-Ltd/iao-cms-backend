{
  "kind": "collectionType",
  "collectionName": "programme_campuses",
  "info": {
    "singularName": "programme-campus",
    "pluralName": "programme-campuses",
    "displayName": "Programme Campus"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "programme": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::programme-hub.programme-hub",
      "inversedBy": "campuses"
    },
    "campus_slug": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "campus_slug",
      "required": true
    },
    "programme_type": {
      "type": "enumeration",
      "enum": [
        "master",
        "lateral",
        "manual-therapy",
        "omt-egypt"
      ]
    },
    "hero": {
      "type": "component",
      "repeatable": false,
      "component": "programme.hero",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content_intro": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "track_groups": {
      "type": "component",
      "repeatable": true,
      "component": "programme.track-group",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "lecturers_section": {
      "type": "component",
      "repeatable": false,
      "component": "programme.lecturers-section",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "practical_items": {
      "type": "component",
      "repeatable": true,
      "component": "programme.practical-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "location_info": {
      "type": "component",
      "repeatable": false,
      "component": "shared.location",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "options": {
      "type": "component",
      "repeatable": false,
      "component": "programme.options",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "breadcrumb_label": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "modules_title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
